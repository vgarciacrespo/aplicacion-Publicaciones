*.dynamic_analysis.dat

# Visual C++ cache files
ipch/
*.aps
*.ncb
*.opendb
*.sdf
*.cachefile
*.VC.db
*.VC.VC.opendb

# Visual Studio profiler
*.psess
*.vsp
*.vspx
*.sap

# Visual Studio Code config
.vscode/

# JetBrains Rider codestyle
.idea/

# MicroSet
.vs/

# Resharper is a tool
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# JustMock code coverage file
*.jmconfig

# Team City build revision config
buildLog.distlock

# Windows image caches
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin used on separate drives
$RECYCLE.BIN/

# VS Code folders
.vscode/
.history/
.ionide/

# Windows Installer files
*.cab
*.msi
*.msm
*.msp

# NuGet Packages
*.nupkg
# NuGet Symbol Packages
*.snupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/
# Uncomment if using NuGet Config to change HTTP cache location
#global-packages/
# If using NuGet.Config to change packages folder location
#packages/

# Log files
*.log

# Diagnostic Device Log
*.diaglog

# Metadata
.metadata

# Mac files
.DS_Store

# User-specific files
*.swp
*.~
~*
