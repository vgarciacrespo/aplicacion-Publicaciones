<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PracticaGrupalEnero.ListarPublicacionesPage"
             Title="ListarPublicacionesPage">
    <VerticalStackLayout>
       <Label Text="Listado de Publicaciones" Margin="20" FontSize="30"></Label>
       <ListView x:Name="PublicacionesListView"
                  ItemSelected="SeleccionarPublicacion">
            <ListView.ItemTemplate>
                <DataTemplate >
                    <TextCell Text="{Binding TituloPublicacion}" Detail="{Binding Tipo}" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </VerticalStackLayout>
</ContentPage>